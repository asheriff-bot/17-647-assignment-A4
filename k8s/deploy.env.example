AWS_REGION=us-east-1
EKS_CLUSTER_NAME=bookstore-dev-BookstoreEKSCluster

# Image registry prefix, e.g. docker.io/username or <acct>.dkr.ecr.us-east-1.amazonaws.com
IMAGE_REGISTRY=YOUR_REGISTRY
IMAGE_TAG=latest

# Datastore / messaging
RDS_ENDPOINT=YOUR_RDS_ENDPOINT
DB_USER=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD
# A4: MongoDB Atlas — paste SRV URI from Atlas → Connect → Drivers (URL-encode password if it has special chars)
MONGO_URI=YOUR_MONGO_URI
MONGO_DB_NAME=books
# Must match Atlas collection and CF parameter MongoCollectionName (e.g. books_asheriff)
MONGO_COLLECTION=books_asheriff
# Optional: only if not using mongodb+srv TLS from URI (Atlas uses TLS by default)
# MONGO_TLS_CA_FILE=/path/to/ca.pem
# A3 course Kafka: list ALL bootstrap brokers, comma-separated (no spaces required).
KAFKA_BROKERS=52.73.13.84:9092,100.51.187.149:9092,52.54.87.18:9092
# Optional (MSK / TLS / SASL). Default PLAINTEXT for plain brokers.
# KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# KAFKA_SSL_CAFILE=/path/to/ca.pem
# KAFKA_SASL_MECHANISM=SCRAM-SHA-512
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# Assignment identifiers
ANDREW_ID=your_andrew_id
EMAIL_ADDRESS=your_email@gmail.com

# CMU 17-647 A3 recommendation service (Canvas):
# - Testing / AWS before submit (zero delay): http://52.73.13.84
# - Gradescope submission (variable delay):   http://100.51.187.149
# OpenAPI path (swagger): GET /recommended-titles/isbn/{isbn}
RECOMMENDATION_SERVICE_URL=http://100.51.187.149
RECOMMENDATION_PATH_TEMPLATE=/recommended-titles/isbn/{isbn}

# SMTP (CRM service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USERNAME=your_email@gmail.com
# Quote if the password contains # (otherwise bash comments and YAML break): SMTP_PASSWORD='secret#1'
SMTP_PASSWORD=app_password
SMTP_SENDER_EMAIL=your_email@gmail.com
